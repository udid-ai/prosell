# Prosell 스토어프론트 환경변수
# `npm run setup` 이 ~/.prosell-mcp/config.json(연결 자격증명)에서 값을 채워 .env.local 을 생성합니다.
# 수동으로 채울 경우 아래를 참고하세요.

# 쇼핑몰 API base (예: https://myshop.example.com)
PROSELL_API_BASE=

# 비회원 상품 조회용 클라이언트 ID
PROSELL_CLIENT_ID=

# 앱키 — 회원 로그인 토큰 발급에 사용. 서버에서만 사용(브라우저 노출 금지).
PROSELL_CLIENT_SECRET=

# (선택) 브라우저가 닿는 base 가 API base 와 다를 때(로컬 도커 등)
# PROSELL_AUTH_BASE=http://localhost:8080

# (선택) 로컬 도커에서 이미지 호스트 치환 (운영은 비워두기)
# PROSELL_IMAGE_BASE=http://localhost:8080
